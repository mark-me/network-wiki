{# full_default.html.j2 — Full-screen wiki for nodes without a type-specific template #}
<h2>{{ label }}</h2>

{% if attrs.description is defined and attrs.description %}
<p>{{ attrs.description }}</p>
{% endif %}

<h3>Attributes</h3>
<table class="table table-sm table-striped">
  <thead><tr><th>Property</th><th>Value</th></tr></thead>
  <tbody>
  {% for key, val in attrs.items() if key not in ('name', 'description') and val is not none %}
  <tr>
    <td>{{ key | replace('_', ' ') | capitalize }}</td>
    <td>{{ val }}</td>
  </tr>
  {% endfor %}
  </tbody>
</table>

{% if neighbours %}
<h3>Connected nodes</h3>
<ul>
  {% for n in neighbours %}
  <li>{{ n }}</li>
  {% endfor %}
</ul>
{% endif %}
