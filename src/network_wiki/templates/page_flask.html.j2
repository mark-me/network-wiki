{% extends "base_network.html.j2" %}

{% block loading_overlay %}
<div id="nw-loading">
  <div class="spinner-border text-secondary" role="status">
    <span class="visually-hidden">Loading…</span>
  </div>
</div>
{% endblock %}

{% block toolbar_extra %}
{% if graphs | length > 1 %}
<select class="form-select form-select-sm" id="nw-graph-picker" onchange="loadGraph(this.value)" title="Switch graph">
  {% for g in graphs %}
  <option value="{{ g.url }}" {% if g.url == data_url %}selected{% endif %}>{{ g.title }}</option>
  {% endfor %}
</select>
{% endif %}

<button class="btn btn-sm btn-outline-secondary" title="Fit graph in view" onclick="network.fit()"><i class="bi bi-fullscreen"></i></button>
{% endblock %}

{% block extra_styles %}
#nw-loading { position: fixed; inset: 0; padding-top: 44px; z-index: 200; display: flex; align-items: center; justify-content: center; background: var(--bs-body-bg); opacity: 0; pointer-events: none; transition: opacity 0.15s ease; }
#nw-loading.visible { opacity: 1; pointer-events: all; }
.spinner-border { width: 2rem; height: 2rem; }
{% endblock %}

{% block head_extra %}
<!-- Flask-specific meta tags if needed -->
{% endblock %}

{% block script_extra %}
const INITIAL_URL = "{{ data_url }}";
NODE_WIKI = {};
EDGE_WIKI = {};
HAS_EDGE_WIKI = false;

async function loadGraph(dataUrl) {
  closePanel();
  showLoading(true);
  try {
    const resp = await fetch(dataUrl);
    if (!resp.ok) throw new Error(`Server returned ${resp.status}`);
    const payload = await resp.json();

    nodeDataset.clear();
    edgeDataset.clear();
    nodeDataset.add(payload.nodes);
    edgeDataset.add(payload.edges);

    NODE_WIKI     = payload.node_wiki;
    EDGE_WIKI     = payload.edge_wiki;
    HAS_EDGE_WIKI = payload.has_edge_wiki;

    document.title = payload.title;
    const titleEl = document.getElementById("nw-current-title");
    if (titleEl) titleEl.textContent = payload.title;

    network.fit();
  } catch (err) {
    console.error("Failed to load graph:", err);
    alert(`Could not load graph: ${err.message}`);
  } finally {
    showLoading(false);
  }
}

function showLoading(visible) {
  const el = document.getElementById("nw-loading");
  if (el) el.classList.toggle("visible", visible);
}

loadGraph(INITIAL_URL);
{% endblock %}