{# mini_default.html.j2 — Compact side-panel wiki for all node types #}
<div class="nw-mini-wiki">

  <div class="nw-node-type">{{ attrs.get('type', 'Node') | upper }}</div>

  {% if attrs.description is defined and attrs.description %}
  <div class="nw-node-desc">{{ attrs.description }}</div>
  {% endif %}

  <div class="nw-attr-grid">
    {% if attrs.status is defined %}
    <div class="nw-attr-box">
      <div class="nw-attr-label">Status</div>
      <div class="nw-attr-value">{{ attrs.status | capitalize }}</div>
    </div>
    {% endif %}

    {% if attrs.owner is defined %}
    <div class="nw-attr-box">
      <div class="nw-attr-label">Owner</div>
      <div class="nw-attr-value">{{ attrs.owner }}</div>
    </div>
    {% endif %}

    <div class="nw-attr-box">
      <div class="nw-attr-label">Incoming</div>
      <div class="nw-attr-value">{{ n_in }}</div>
    </div>
    <div class="nw-attr-box">
      <div class="nw-attr-label">Outgoing</div>
      <div class="nw-attr-value">{{ n_out }}</div>
    </div>
  </div>

  <div class="nw-connections">
    Connected to <strong>{{ n_in + n_out }}</strong> other nodes
  </div>

</div>
